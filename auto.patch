+/**
+ * Search for a skill by partial name or description match, excluding passives.
+ * Checks both aegis name and english description (case-insensitive substring).
+ * @param str Search string
+ * @return Skill ID of first match, or 0 if not found
+ **/
+uint16 skilldb_searchname(const char* str) {
+	if (str == nullptr || *str == '\0')
+		return 0;
+
+	// Pass 1: exact match on desc or aegis name
+	for (const auto& it : skill_db) {
+		std::shared_ptr<s_skill_db> skill = it.second;
+		if (skill == nullptr || skill->inf == INF_PASSIVE_SKILL)
+			continue;
+		if (strcmpi(skill->desc, str) == 0 ||
+			strcmpi(skill->name, str) == 0)
+			return it.first;
+	}
+
+	// Pass 2: substring fallback
+	for (const auto& it : skill_db) {
+		std::shared_ptr<s_skill_db> skill = it.second;
+		if (skill == nullptr || skill->inf == INF_PASSIVE_SKILL)
+			continue;
+		if (stristr(skill->name, str) != nullptr ||
+			stristr(skill->desc, str) != nullptr)
+			return it.first;
+	}
+
+	return 0;
+}
